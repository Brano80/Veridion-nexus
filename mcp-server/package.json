{
  "name": "veridion-nexus-mcp",
  "mcpName": "io.github.Brano80/Veridion-nexus",
  "version": "1.0.9",
  "description": "Veridion Nexus MCP server - GDPR Art. 44-49 runtime compliance for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "veridion-nexus-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "tsx test-client.ts",
    "test:ts-node": "ts-node --esm test-client.ts",
    "mcp:init": ".\\mcp-publisher.exe init",
    "mcp:login": ".\\mcp-publisher.exe login github",
    "mcp:publish": ".\\mcp-publisher.exe publish",
    "mcp": ".\\mcp-publisher.exe"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "jose": "^6.2.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0"
  }
}
