FROM node:20-alpine

WORKDIR /app

# Build argument for Dashboard URL (required at build time for NEXT_PUBLIC_ vars)
ARG NEXT_PUBLIC_DASHBOARD_URL
ENV NEXT_PUBLIC_DASHBOARD_URL=$NEXT_PUBLIC_DASHBOARD_URL
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

# Copy package files
COPY veridion-landing/package*.json ./

# Install dependencies
RUN npm ci

# Copy landing page source code
COPY veridion-landing .

# Build the Next.js application
RUN npm run build

EXPOSE 3001

# Start the production server
CMD ["npm", "start"]
