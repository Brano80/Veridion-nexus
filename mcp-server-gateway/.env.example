# ── Rust API connection ──
AL_API_BASE_URL=https://api.veridion-nexus.eu
AL_SERVICE_TOKEN=your_service_token_here

# ── Auth mode ──
# dev_bypass: skip JWT, use fixed client_id (for local testing)
# jwks: real OAuth 2.1 token validation (production)
AL_AUTH_MODE=dev_bypass
AL_DEV_CLIENT_ID=your_agent_id_here

# Production-only (when AL_AUTH_MODE=jwks):
# AL_OAUTH_ISSUER=https://auth.example.com
# AL_OAUTH_AUDIENCE=veridion-nexus-al
# AL_JWKS_URI=https://auth.example.com/.well-known/jwks.json

# ── Upstream MCP server ──
# stdio: launches upstream as subprocess (Claude Desktop, Cursor)
# sse: connects to upstream over HTTP SSE (remote/cloud servers)
UPSTREAM_MCP_MODE=stdio
UPSTREAM_MCP_COMMAND=node /path/to/your/mcp-server/dist/index.js
# UPSTREAM_MCP_ARGS=[]
# UPSTREAM_MCP_URL=http://localhost:3001/sse

# ── Optional ──
AL_ORIGIN_COUNTRY=DE
# AL_EEA_EXTRA_COUNTRIES=
# UPSTREAM_MCP_RECONNECT_MS=5000
# AL_AGENT_TOKEN=
