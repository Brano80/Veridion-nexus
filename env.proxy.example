# ── AL Proxy environment variables ───────────────────────────────────────────
# Add these to your existing .env.example / .env

# Rust API base URL (the existing Veridion Nexus backend)
AL_API_BASE_URL=http://localhost:8080

# Internal service token — a JWT the Rust API accepts for proxy→API calls
# Generate with: openssl rand -hex 32
AL_SERVICE_TOKEN=

# OAuth 2.1 configuration
# For local dev without a real auth server, use dev_bypass mode (see below)
AL_AUTH_MODE=jwks
AL_OAUTH_ISSUER=https://auth.veridion-nexus.eu
AL_OAUTH_AUDIENCE=veridion-nexus-al
# Optional: defaults to {AL_OAUTH_ISSUER}/.well-known/jwks.json
# AL_JWKS_URI=

# ── Dev bypass (local development only — NEVER in production) ──────────────
# AL_AUTH_MODE=dev_bypass
# AL_DEV_CLIENT_ID=test-agent-client-id-001

# Agent Bearer token (stdio mode: passed by agent launcher, not set manually)
# AL_AGENT_TOKEN=
