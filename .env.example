# Veridion API - example environment variables
# Copy to .env and fill in values.

# Required
DATABASE_URL=postgres://user:password@localhost:5432/veridion_api

# Optional
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://app.veridion-nexus.eu
RUST_ENV=development
JWT_SECRET=your_jwt_secret_change_in_production

# Email (welcome + password reset; optional — omit SMTP_* to skip sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@veridion-nexus.eu

# Evidence seal salt (optional override)
# NEXUS_SEAL_SALT=

# Migrations (API container defaults to /app/migrations; rarely needed)
# MIGRATIONS_PATH=/app/migrations
# RESET_MIGRATIONS=0

# ── AL Proxy environment variables ───────────────────────────────────────────

# Rust API base URL (the existing Veridion Nexus backend)
AL_API_BASE_URL=http://localhost:8080

# Internal service token — a JWT the Rust API accepts for proxy→API calls (required in production for /api/acm/*)
# Generate with: openssl rand -hex 32
AL_SERVICE_TOKEN=

# OAuth 2.1 configuration
# For local dev without a real auth server, use dev_bypass mode (see below)
AL_AUTH_MODE=jwks
AL_OAUTH_ISSUER=https://auth.veridion-nexus.eu
AL_OAUTH_AUDIENCE=veridion-nexus-al
# Optional: defaults to {AL_OAUTH_ISSUER}/.well-known/jwks.json
# AL_JWKS_URI=

# ── Dev bypass (local development only — NEVER in production) ──────────────
# AL_AUTH_MODE=dev_bypass
# AL_DEV_CLIENT_ID=test-agent-client-id-001

# Agent Bearer token (stdio mode: passed by agent launcher, not set manually)
# AL_AGENT_TOKEN=

# ── Upstream MCP server (Phase 1) ─────────────────────────────────────────────
# Mode: 'stdio' (default, for local/subprocess) or 'sse' (for remote/cloud)
UPSTREAM_MCP_MODE=stdio

# stdio mode: shell command to launch the upstream MCP server
# Example: point at any other MCP server binary
UPSTREAM_MCP_COMMAND=node /absolute/path/to/upstream/dist/index.js
# Optional JSON array of extra args: UPSTREAM_MCP_ARGS=["--some-flag"]

# sse mode: HTTP SSE endpoint of the upstream MCP server
# UPSTREAM_MCP_URL=http://localhost:3001/sse

# Reconnect delay if upstream disconnects (ms, default 5000)
# UPSTREAM_MCP_RECONNECT_MS=5000

# ── Accountability Ledger proxy — Phase 2 (optional) ───────────────────────────
# ISO 3166-1 alpha-2 origin country for DataTransferRecord.origin_country
# AL_ORIGIN_COUNTRY=DE
# Extra country codes treated as EEA for transfer logging (comma-separated)
# AL_EEA_EXTRA_COUNTRIES=
